# === ColdCraft Configuration ===

# Gemini Pro API Key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# SMTP Email Settings (Gmail: use App Password from https://myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_EMAIL=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here

# Google Sheets (optional - path to service account JSON key)
GOOGLE_SHEETS_CREDENTIALS=credentials.json

# Rate Limiting
EMAIL_DELAY_SECONDS=30
MAX_EMAILS_PER_HOUR=20

# Flask
FLASK_SECRET_KEY=change_this_to_a_random_string
FLASK_DEBUG=true
